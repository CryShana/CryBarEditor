<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:micons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
		xmlns:ce="using:CryBarEditor.Windows"
        mc:Ignorable="d" d:DesignWidth="440" d:DesignHeight="320"
        x:Class="CryBarEditor.Windows.XsExportDialog"
		x:DataType="ce:XsExportDialog"
		WindowStartupLocation="CenterOwner"
		WindowDecorations="None"
		ExtendClientAreaToDecorationsHint="True"
		Foreground="#d9d9d9"
		Background="#141414"
		DataContext="{Binding RelativeSource={RelativeSource Self}}"
		CanResize="False" Width="440" Height="320"
        Title="XS Export Mode">
	<Border Padding="10" BorderThickness="2" BorderBrush="#d9d9d9">
		<DockPanel>
			<!-- Title -->
			<TextBlock DockPanel.Dock="Top" Text="XS Export Mode" FontWeight="Bold" FontSize="18" Margin="0,0,0,10" />

			<!-- Buttons (docked bottom) -->
			<DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0" LastChildFill="False">
				<Button DockPanel.Dock="Right" Content="Cancel" Click="CancelClick" IsCancel="True" Margin="8,0,0,0" />
				<Button DockPanel.Dock="Right" Content="Export" Click="ExportClick" IsDefault="True" />
			</DockPanel>

			<!-- Warning (docked above buttons, shown when trigger_data not found and lossy selected) -->
			<Border DockPanel.Dock="Bottom" Background="#2a2a1e" Padding="8" CornerRadius="4" Margin="0,8,0,0"
					IsVisible="{Binding ShowWarning}">
				<StackPanel Orientation="Horizontal">
					<micons:MaterialIcon Kind="AlertOutline" Width="16" Height="16"
										 Margin="0,0,6,0" Foreground="#f5a742" VerticalAlignment="Top" />
					<TextBlock Text="{Binding WarningText}" Foreground="#e0d8a0"
							   TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12" />
				</StackPanel>
			</Border>

			<!-- Option bubbles -->
			<StackPanel Margin="0,4,0,0" Spacing="8">

				<!-- Lossy option (yellow/amber tint) -->
				<Border Background="#2a2a1e" Padding="10" CornerRadius="4" BorderThickness="2"
						BorderBrush="{Binding LossyBorderBrush}">
					<RadioButton IsChecked="{Binding IsLossy}" Margin="0">
						<StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<micons:MaterialIcon Kind="FileExportOutline" Width="18" Height="18"
													 Foreground="#edc042" VerticalAlignment="Center" />
								<TextBlock Text="Lossy (clean)" FontWeight="Bold" FontSize="14"
										   Foreground="#edc042" VerticalAlignment="Center" />
							</StackPanel>
							<TextBlock Text="Clean XS output with no metadata comments. One-way export - converting back to XML/TRG with full accuracy unlikely."
									   Foreground="#c0b880" FontSize="12" Margin="24,4,0,0" TextWrapping="Wrap" />
						</StackPanel>
					</RadioButton>
				</Border>

				<!-- Lossless option (green tint) -->
				<Border Background="#1e2a1e" Padding="10" CornerRadius="4" BorderThickness="2"
						BorderBrush="{Binding LosslessBorderBrush}">
					<RadioButton IsChecked="{Binding IsLossless}" Margin="0">
						<StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="6">
								<micons:MaterialIcon Kind="ShieldCheckOutline" Width="18" Height="18"
													 Foreground="#78f542" VerticalAlignment="Center" />
								<TextBlock Text="Lossless (with metadata)" FontWeight="Bold" FontSize="14"
										   Foreground="#78f542" VerticalAlignment="Center" />
							</StackPanel>
							<TextBlock Text="Embeds // @CryBar: comments that preserve all trigger metadata for perfect XML/TRG roundtripping."
									   Foreground="#80c080" FontSize="12" Margin="24,4,0,0" TextWrapping="Wrap" />
						</StackPanel>
					</RadioButton>
				</Border>

			</StackPanel>
		</DockPanel>
	</Border>
</Window>
