<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:ce="using:CryBarEditor.Windows"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="200"
        x:Class="CryBarEditor.Windows.SettingsWindow"
		x:DataType="ce:SettingsWindow"
		WindowStartupLocation="CenterOwner"
		ExtendClientAreaChromeHints="NoChrome"
		ExtendClientAreaToDecorationsHint="True"
		Foreground="#d9d9d9"
		Background="#141414"
		DataContext="{Binding RelativeSource={RelativeSource Self}}"
		CanResize="False" Width="420" Height="280"
        Title="Settings">
	<Border Padding="10" BorderThickness="2" BorderBrush="#d9d9d9">
		<DockPanel>
			<TextBlock DockPanel.Dock="Top" Text="Settings" FontWeight="Bold" FontSize="18" Margin="0,0,0,8" />

			<DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0" LastChildFill="False">
				<Button DockPanel.Dock="Right" Content="Cancel" Click="CancelClick" IsCancel="True" Margin="8,0,0,0" />
				<Button DockPanel.Dock="Right" Content="OK" Click="OKClick" IsDefault="True" />
			</DockPanel>

			<StackPanel Spacing="10">
				<StackPanel>
					<TextBlock Text="Editor command" FontWeight="Bold" Margin="0,0,0,4" />
					<TextBox Text="{Binding EditorCommand, Mode=TwoWay}" Watermark="code &quot;{file}&quot;" />
					<TextBlock Text=" {file} is placeholder for exported file path"
							   Foreground="Gray" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap" />
				</StackPanel>
				<StackPanel>
					<TextBlock Text="String table language" FontWeight="Bold" Margin="0,0,0,4" />
					<TextBox Text="{Binding StringTableLanguage, Mode=TwoWay}" Watermark="English" />
					<TextBlock Text="Language folder used when navigating to STR_ keys (default: English)"
							   Foreground="Gray" FontSize="14" Margin="0,4,0,0" TextWrapping="Wrap" />
				</StackPanel>
			</StackPanel>
		</DockPanel>
	</Border>
</Window>
