<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
		xmlns:cb="using:CryBar"
		xmlns:ce="using:CryBarEditor"
		xmlns:cc="using:CryBarEditor.Classes"
		xmlns:converters="using:CryBarEditor.Converters"
		xmlns:micons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
		mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="450"
        x:Class="CryBarEditor.MainWindow"
		DataContext="{Binding RelativeSource={RelativeSource Self}}"
        Title="CryBarEditor" x:DataType="ce:MainWindow"
		Foreground="#d9d9d9"
		Background="#141414"
		x:Name="mainWindow">
	<Window.Styles>
		<Style Selector="ListBox">
			<Setter Property="Background" Value="#1c1c1c" />
		</Style>
		<Style Selector="TextBlock.BAR">
			<Setter Property="Foreground" Value="#6f96bf"/>
		</Style>
		<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
			<Setter Property="Background" Value="#2b3c57" />
		</Style>

		<Style Selector="ListBoxItem:focus /template/ ContentPresenter">
			<Setter Property="Background" Value="#2b3c57" />
		</Style>

		<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#1a2436" />
		</Style>

		<Style Selector="Menu MenuItem">
			<Setter Property="Foreground" Value="#ebebeb" />
		</Style>

		<!-- TextBox clear button -->
		<Style Selector="TextBox.clearable">
			<Setter Property="Padding" Value="8,5,26,5" />
		</Style>

		<!-- TMM TabControl dark theme -->
		<Style Selector="TabControl#_tmmTabControl">
			<Setter Property="Background" Value="#1c1c1c" />
		</Style>
		<Style Selector="TabControl#_tmmTabControl TabItem">
			<Setter Property="Background" Value="#1c1c1c" />
			<Setter Property="Foreground" Value="#a0a0a0" />
			<Setter Property="Padding" Value="12,6" />
		</Style>
		<Style Selector="TabControl#_tmmTabControl TabItem:selected">
			<Setter Property="Background" Value="#2b3c57" />
			<Setter Property="Foreground" Value="#d9d9d9" />
		</Style>
		<Style Selector="TabControl#_tmmTabControl TabItem:pointerover">
			<Setter Property="Background" Value="#1a2436" />
			<Setter Property="Foreground" Value="#d9d9d9" />
		</Style>
	</Window.Styles>
	<Window.Resources>
		<converters:IsOverridenToBoolConverter x:Key="overridenConverter" />
		
		<ContextMenu x:Key="SharedContextMenu" Opened="ContextMenu_Opened">
			<MenuItem Header="Copy file name"
					  Icon="{micons:MaterialIconExt Kind=ContentCopy}"
					  Click="MenuItem_CopyFileName" />

			<MenuItem Header="Copy file path"
					  Icon="{micons:MaterialIconExt Kind=ContentCopy}"
					  Click="MenuItem_CopyFilePath" />

			<Separator IsVisible="{Binding CanExport}" />

			<MenuItem Header="Open export directory"
					IsVisible="{Binding CanExport}" Icon="{micons:MaterialIconExt Kind=OpenInNew}"
					Click="MenuItem_ExportSelectedOpenDirectory" />

			<MenuItem Header="Open exported in editor"
					IsVisible="{Binding CanOpenInEditor}" Icon="{micons:MaterialIconExt Kind=FileEditOutline}"
					Click="MenuItem_OpenExportedInEditor" />

			<MenuItem Header="{Binding ContextSelectedItemsCount, StringFormat='Export {0} selected (copy)'}"
					IsVisible="{Binding CanExport}" Icon="{micons:MaterialIconExt Kind=Export}"
					Click="MenuItem_ExportSelectedRaw" />

			<MenuItem Header="{Binding ContextSelectedItemsCount, StringFormat='Export {0} selected (converted)'}"
					IsVisible="{Binding CanExport}" Icon="{micons:MaterialIconExt Kind=Export}"
					Click="MenuItem_ExportSelectedConverted" />

			<MenuItem Header="{Binding ContextSelectedItemsCount, StringFormat='Export {0} selected (copy+converted)'}"
					IsVisible="{Binding CanExport}" Icon="{micons:MaterialIconExt Kind=Export}"
					Click="MenuItem_ExportSelectedRawConverted" />

			<Separator />

			<MenuItem Header="{Binding ContextSelectedItemsCount, StringFormat='Advanced Export ({0} selected)...'}"
					Icon="{micons:MaterialIconExt Kind=CogOutline}" IsVisible="{Binding CanExport}"
					Click="MenuItem_AdvancedExport" />

			<MenuItem Header="{Binding ContextSelectedItemsCount, StringFormat='Export {0} selected to...'}"
					Icon="{micons:MaterialIconExt Kind=FolderMoveOutline}"
					Click="MenuItem_ExportTo" />

			<Separator IsVisible="{Binding SelectedIsDDT}"/>

			<MenuItem Header="Replace image and export DDT"
					IsVisible="{Binding SelectedIsDDT}" Icon="{micons:MaterialIconExt Kind=FileReplaceOutline}"
					Click="MenuItem_ReplaceImageAndExportDDT"/>

			<Separator IsVisible="{Binding SelectedCanHaveAdditiveMod}"/>

			<MenuItem Header="Create additive mod" Icon="{micons:MaterialIconExt Kind=FileEditOutline}"
					IsVisible="{Binding SelectedCanHaveAdditiveMod}"
					Click="MenuItem_CreateNewAdditiveMod"/>

			<Separator />

			<MenuItem Header="{Binding QuickAccessToggleText}"
					  Icon="{micons:MaterialIconExt Kind=Star}"
					  Click="MenuItem_ToggleQuickAccess" />
		</ContextMenu>
	</Window.Resources>

	<DockPanel>
		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#1c1c1c">
			<TextBlock Text="TOOLS ->" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="Gray" />
			<Menu Margin="5,0,0,0">
				<MenuItem Header="_Convert">
					<MenuItem Header="XML to XMB" Click="MenuItem_ConvertXMLtoXMB" />
					<MenuItem Header="XMB to XML" Click="MenuItem_ConvertXMBtoXML" />
					<MenuItem Header="DDT to TGA" Click="MenuItem_ConvertDDTtoTGA" />
					<MenuItem Header="DDT to PNG" Click="MenuItem_ConvertDDTtoPNG" />
					<MenuItem Header="Image to DDT" Click="MenuItem_ConvertToDDT" />
					<MenuItem Header="TMM to OBJ" Click="MenuItem_ConvertTMMtoOBJ" />
					<MenuItem Header="TMM to glTF" Click="MenuItem_ConvertTMMtoGLTF" />
				</MenuItem>
				<MenuItem Header="Compress">
					<MenuItem Header="Alz4" Click="MenuItem_CompressAlz4" />
					<MenuItem Header="L33t" Click="MenuItem_CompressL33t" />
				</MenuItem>
				<MenuItem Header="Decompress" Click="MenuItem_Decompress" />
				<MenuItem Header="Script">
					<MenuItem Header="Make RM friendly" Click="MenuItem_XStoRM" />
				</MenuItem>
				<MenuItem Header="Search" Click="MenuItem_Search" />
				<MenuItem Header="Settings" Click="MenuItem_Settings" />
			</Menu>
		</StackPanel>
		<Border Padding="10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="300" MinWidth="200" />
					<ColumnDefinition Width="5" MinWidth="5" />
					<ColumnDefinition Width="400" MinWidth="200" />
					<ColumnDefinition Width="5" MinWidth="5" />
					<ColumnDefinition Width="*" MinWidth="150" />
				</Grid.ColumnDefinitions>

				<!-- ROOT DIRECTORY FILE ENTRIES -->
				<DockPanel Grid.Row="1" Grid.Column="0">
					<Label DockPanel.Dock="Top" Content="Root Directory" FontWeight="Bold"  FontSize="16"/>
					<DockPanel DockPanel.Dock="Top" Margin="0,5,0,0">
						<Button Content="{micons:MaterialIconExt Kind=FolderArrowUpOutline}" Padding="4"
								Click="LoadDir_Click" Margin="0,0,6,6" />
						<TextBlock DockPanel.Dock="Top" Text="{Binding RootDirectory}" Foreground="Gray" Margin="0,4,0,0"
								   Cursor="Hand" PointerPressed="RootDirectoryPath_Click"
								   TextTrimming="CharacterEllipsis" />
					</DockPanel>

					<Grid DockPanel.Dock="Top">
						<TextBox Classes="clearable" Text="{Binding FilesQuery, Mode=TwoWay}" Watermark="Filter files" TextChanged="FilterTextBox_TextChanged" />
						<Button Classes="filterClear" HorizontalAlignment="Right" VerticalAlignment="Center"
								Focusable="False" IsTabStop="False" Click="FilterClear_Click"
								IsVisible="False" Background="Transparent" BorderThickness="0"
								Padding="2" Margin="0,0,4,0" Cursor="Hand">
							<micons:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="#808080" />
						</Button>
					</Grid>
					<TextBlock DockPanel.Dock="Top" Margin="0,6,0,0">
						<Run Text="Guessed Root: " FontWeight="Bold"/>
						<Run Text="{Binding RootFileRootPath}"/>
					</TextBlock>
					<ListBox ItemsSource="{Binding RootFileEntries}" Margin="0,10,0,0"
							 SelectionMode="Multiple"
							 SelectedItems="{Binding SelectedRootFileEntries, Mode=TwoWay}"
							 SelectedItem="{Binding SelectedRootFileEntry, Mode=TwoWay}"
							 ContextMenu="{StaticResource SharedContextMenu}">
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="cc:RootFileEntry">
								<StackPanel Orientation="Horizontal" Height="19">
									<TextBlock Text="{Binding DirectoryPath}" Foreground="#808080" VerticalAlignment="Center"/>
									<TextBlock Text="{Binding Name}" Classes.BAR="{Binding IsBAR}" VerticalAlignment="Center"/>
									<micons:MaterialIcon Kind="FileExportOutline" VerticalAlignment="Center"
														 Margin="5,0,0,0" Foreground="#e3bd54"
														 Width="19" Height="19" Background="Transparent"
														 ToolTip.Tip="Overriden in export directory">
										<micons:MaterialIcon.IsVisible>
											<MultiBinding Converter="{StaticResource overridenConverter}">
												<Binding Path="." />
												<Binding Path="#mainWindow" />
												<Binding Path="#mainWindow.((ce:MainWindow)DataContext).ShowOverridenIcons" />
											</MultiBinding>
										</micons:MaterialIcon.IsVisible>
									</micons:MaterialIcon>
									<micons:MaterialIcon Kind="FilePlusOutline" VerticalAlignment="Center"
														 Margin="3,0,0,0" Foreground="#6ecf8e"
														 Width="19" Height="19" Background="Transparent"
														 ToolTip.Tip="Has additive mod in export directory">
										<micons:MaterialIcon.IsVisible>
											<MultiBinding Converter="{StaticResource overridenConverter}"
														  ConverterParameter="additive">
												<Binding Path="." />
												<Binding Path="#mainWindow" />
												<Binding Path="#mainWindow.((ce:MainWindow)DataContext).ShowOverridenIcons" />
											</MultiBinding>
										</micons:MaterialIcon.IsVisible>
									</micons:MaterialIcon>
								</StackPanel>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</DockPanel>

				<GridSplitter Grid.Row="1" Grid.Column="1" Width="5" Margin="3" />

				<!-- BAR ARCHIVE FILE ENTRIES / FMOD BANK -->
				<Grid Grid.Row="1" Grid.Column="2">
					<!-- BAR File Panel -->
					<DockPanel IsVisible="{Binding !IsBankFileSelected}">
						<Label DockPanel.Dock="Top" Content="BAR File" FontWeight="Bold" FontSize="16"/>
						<DockPanel DockPanel.Dock="Top" Margin="0,5,0,0">
							<Button Content="{micons:MaterialIconExt Kind=ArchiveArrowUpOutline}" Padding="4" Click="LoadBAR_Click" Margin="0,0,6,6"/>
							<Label DockPanel.Dock="Top" Content="{Binding LoadedBARFilePathOrRelative}" Foreground="Gray" Margin="0,2,0,0" />
						</DockPanel>
						<Grid DockPanel.Dock="Top">
							<TextBox Classes="clearable" Text="{Binding EntryQuery, Mode=TwoWay}" Watermark="Filter BAR entries" TextChanged="FilterTextBox_TextChanged" />
							<Button Classes="filterClear" HorizontalAlignment="Right" VerticalAlignment="Center"
									Focusable="False" IsTabStop="False" Click="FilterClear_Click"
									IsVisible="False" Background="Transparent" BorderThickness="0"
									Padding="2" Margin="0,0,4,0" Cursor="Hand">
								<micons:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="#808080" />
							</Button>
						</Grid>
						<DockPanel DockPanel.Dock="Top" Margin="0,6,0,0">
							<TextBlock DockPanel.Dock="Left" HorizontalAlignment="Left">
								<Run Text="Root: " FontWeight="Bold"/>
								<Run Text="{Binding BarFileRootPath}"/>
							</TextBlock>
							<TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right">
								<Run Text="Entries: " FontWeight="Bold"/>
								<Run Text="{Binding BarFile.Entries.Count}"/>
							</TextBlock>
						</DockPanel>
						
						<ListBox ItemsSource="{Binding BarEntries}" Margin="0,10,0,0"
								SelectionMode="Multiple"
								SelectedItems="{Binding SelectedBarFileEntries, Mode=TwoWay}"
								SelectedItem="{Binding SelectedBarEntry, Mode=TwoWay}"
								ContextMenu="{StaticResource SharedContextMenu}">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="cb:BarFileEntry">
									<StackPanel Orientation="Horizontal" Height="19">
										<TextBlock Text="{Binding DirectoryPath}" Foreground="#808080" VerticalAlignment="Center"/>
										<TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
										<micons:MaterialIcon Kind="FileExportOutline" VerticalAlignment="Center"
															Margin="5,0,0,0" Foreground="#e3bd54"
															Width="19" Height="19" Background="Transparent"
															ToolTip.Tip="Overriden in export directory">
											<micons:MaterialIcon.IsVisible>
												<MultiBinding Converter="{StaticResource overridenConverter}">
													<Binding Path="." />
													<Binding Path="#mainWindow" />
													<Binding Path="#mainWindow.((ce:MainWindow)DataContext).ShowOverridenIcons" />
												</MultiBinding>
											</micons:MaterialIcon.IsVisible>
										</micons:MaterialIcon>
										<micons:MaterialIcon Kind="FilePlusOutline" VerticalAlignment="Center"
															 Margin="3,0,0,0" Foreground="#6ecf8e"
															 Width="19" Height="19" Background="Transparent"
															 ToolTip.Tip="Has additive mod in export directory">
											<micons:MaterialIcon.IsVisible>
												<MultiBinding Converter="{StaticResource overridenConverter}"
															  ConverterParameter="additive">
													<Binding Path="." />
													<Binding Path="#mainWindow" />
													<Binding Path="#mainWindow.((ce:MainWindow)DataContext).ShowOverridenIcons" />
												</MultiBinding>
											</micons:MaterialIcon.IsVisible>
										</micons:MaterialIcon>
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</DockPanel>

					<!-- FMOD Bank Panel -->
					<DockPanel IsVisible="{Binding IsBankFileSelected}">
						<Label DockPanel.Dock="Top" Content="FMOD Bank" FontWeight="Bold" FontSize="16"/>
						<DockPanel DockPanel.Dock="Top" Margin="0,5,0,0">
							<Button Content="{micons:MaterialIconExt Kind=FileMusic}" Padding="4" Click="LoadBank_Click" Margin="0,0,6,6"/>
							<Label DockPanel.Dock="Top" Content="{Binding LoadedBankFilePathOrRelative}" Foreground="Gray" Margin="0,2,0,0" />
						</DockPanel>
						<Grid DockPanel.Dock="Top">
							<TextBox Classes="clearable" Text="{Binding BankQuery, Mode=TwoWay}" Watermark="Filter events" TextChanged="FilterTextBox_TextChanged" />
							<Button Classes="filterClear" HorizontalAlignment="Right" VerticalAlignment="Center"
									Focusable="False" IsTabStop="False" Click="FilterClear_Click"
									IsVisible="False" Background="Transparent" BorderThickness="0"
									Padding="2" Margin="0,0,4,0" Cursor="Hand">
								<micons:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="#808080" />
							</Button>
						</Grid>
						<TextBlock DockPanel.Dock="Top" Margin="0,6,0,0">
							<Run Text="Events: " FontWeight="Bold"/>
							<Run Text="{Binding FmodBank.Events.Length}"/>
						</TextBlock>
						
						<ListBox ItemsSource="{Binding BankEntries}" Margin="0,10,0,0"
								SelectionMode="Single"
								SelectedItems="{Binding SelectedBankEntries, Mode=TwoWay}"
								SelectedItem="{Binding SelectedBankEntry, Mode=TwoWay}">
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="ce:FMODEvent">
									<StackPanel Orientation="Horizontal" Height="19">
										<micons:MaterialIcon Kind="MusicNote" Width="16" Height="16" 
														Margin="0,0,5,0" Foreground="#6f96bf" 
														VerticalAlignment="Center"/>
										<TextBlock Text="{Binding Path}" VerticalAlignment="Center"/>
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
							<ListBox.ContextMenu>
								<ContextMenu>
									<MenuItem Header="Play" 
											Icon="{micons:MaterialIconExt Kind=Play}"
											Click="BankItem_Play" />
									<MenuItem Header="Export"
										Icon="{micons:MaterialIconExt Kind=Export}"
										Click="BankItem_Export" />
									<Separator IsVisible="{Binding #mainWindow.((ce:MainWindow)DataContext).CanExportAllSounds}"/>
									<MenuItem Header="Export All Sounds (via soundset)"
										Icon="{micons:MaterialIconExt Kind=MusicBoxMultiple}"
										Click="BankItem_ExportAllSounds"
										IsVisible="{Binding #mainWindow.((ce:MainWindow)DataContext).CanExportAllSounds}" />
									<Separator />
									<MenuItem Header="{Binding #mainWindow.((ce:MainWindow)DataContext).FmodQuickAccessToggleText}"
										Icon="{micons:MaterialIconExt Kind=Star}"
										Click="MenuItem_ToggleQuickAccessFmod" />
								</ContextMenu>
							</ListBox.ContextMenu>
						</ListBox>
					</DockPanel>
				</Grid>

				<GridSplitter Grid.Row="1" Grid.Column="3" Width="5" Margin="3"  />

				<!-- EXPORT SETTINGS + PREVIEWER -->
				<DockPanel Grid.Row="1" Grid.Column="4">
					<DockPanel DockPanel.Dock="Top">
						<Button DockPanel.Dock="Right" Click="QuickAccess_Click"
								Padding="4" Margin="6,0,6,0"
								ToolTip.Tip="Quick Access"
								Background="Transparent" BorderThickness="0" Cursor="Hand">
							<micons:MaterialIcon Kind="Star" Width="18" Height="18" Foreground="#e3bd54" />
						</Button>
						<Label Content="Export Root Directory" FontWeight="Bold" FontSize="16"/>
					</DockPanel>
					<DockPanel DockPanel.Dock="Top" Margin="0,5,0,0">
						<Button Content="{micons:MaterialIconExt Kind=FolderArrowDownOutline}" Padding="4" Click="SelectExportRootDir_Click" Margin="0,0,6,6"/>
						<TextBlock Text="{Binding ExportRootDirectory}" Foreground="Gray" Margin="0,4,0,0"
								   Cursor="Hand" PointerPressed="ExportDirectoryPath_Click"
								   TextTrimming="CharacterEllipsis" />
					</DockPanel>
					<TextBlock DockPanel.Dock="Top" Margin="0,10,0,0" FontSize="16">
						<Run Text="Previewing: " FontWeight="Bold" />
						<Run Text="{Binding PreviewedFileName}" Foreground="#ffe6a1" />
						<Run Text="{Binding PreviewedFileNote}" Foreground="#edc042" />
					</TextBlock>
					<SelectableTextBlock DockPanel.Dock="Top"
							   Text="{Binding PreviewedFileData}"
							   Margin="0,3,0,13" Foreground="Gray"  />
					<Grid x:Name="_gridPreview">
						<!-- Flat preview for non-TMM files -->
						<Panel x:Name="_flatPreview">
							<Image x:Name="_imgPreview" ZIndex="1"
								HorizontalAlignment="Left" VerticalAlignment="Top"
								Stretch="Uniform" StretchDirection="DownOnly" />
							<ae:TextEditor x:Name="_txtEditor"
								IsReadOnly="True"
								Text="Click on any file to preview it here"
								ShowLineNumbers="True"
								FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
								Background="#1c1c1c"/>
						</Panel>

						<!-- Tabbed preview for TMM files -->
						<TabControl x:Name="_tmmTabControl" IsVisible="False">
							<TabItem Header="Metadata">
								<ae:TextEditor x:Name="_tmmMetadataEditor"
									IsReadOnly="True"
									ShowLineNumbers="True"
									FontFamily="Cascadia Code,Consolas,Menlo,Monospace"
									Background="#1c1c1c"/>
							</TabItem>
							<TabItem Header="3D Preview">
								<DockPanel>
									<StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
												HorizontalAlignment="Right" Margin="0,4,0,0">
										<TextBlock x:Name="_3dStatusText"
											VerticalAlignment="Center" Margin="0,0,8,0"
											Foreground="Gray" />
										<Button Content="Reset Camera"
											Click="ResetCamera_Click" Padding="6,2" />
									</StackPanel>
									<Border x:Name="_3dViewContainer" Background="#0a0a0a" />
								</DockPanel>
							</TabItem>
						</TabControl>
					</Grid>
				</DockPanel>
			</Grid>
		</Border>
	</DockPanel>
</Window>
